# Churn Prediction AI AI - Environment Variables Configuration

# ===========================================
# Supabase Configuration (Required)
# ===========================================
# Get these from: https://supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ===========================================
# API Configuration (Optional)
# ===========================================
# Leave empty for same-origin (Vercel deployment)
# Set to http://localhost:8000 for local backend development
# VITE_API_URL=

# ===========================================
# Development Settings (Optional)
# ===========================================
# Uncomment for development mode
# VITE_DEV_MODE=true

# ===========================================
# Analytics & Monitoring (Optional)
# ===========================================
# Add your analytics IDs here
# VITE_GA_ID=
# VITE_SENTRY_DSN=

# ===========================================
# Feature Flags (Optional)
# ===========================================
# VITE_ENABLE_AUTH=false
# VITE_ENABLE_EXPORT=false
# VITE_ENABLE_NOTIFICATIONS=false
